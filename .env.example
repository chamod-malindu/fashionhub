# Environment Variables — FashionHub
# Copy this file to .env.local for local development.
# No secrets are required to run this project locally.
# The app uses an in-memory store with a seeded mock user.

# Optional: override the default Next.js port (default: 3000)
# PORT=3000

# ------------------------------------------------------------
# Future extension (not needed for the current in-memory build)
# ------------------------------------------------------------
# DATABASE_URL=          # e.g. postgresql://... or mongodb+srv://...
# NEXTAUTH_SECRET=       # Required if you add next-auth
# NEXTAUTH_URL=http://localhost:3000
